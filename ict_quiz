n=int(input("Enter n:"))
def say(n):
    l=0
    while n!=0:
        l+=1
        n//=10
    return l

def sol(number):
    l=say(number)
    s=0
    while number!=0:
        r=number%10
        s=s+l*r
        number//=10
        l-=1
    return s
def sag(number):
    number=int(str(number)[::-1])
    l=say(number)
    c=0
    while number!=0:
        r=number%10
        c=c+l*r
        number//=10
        l-=1
    return c
