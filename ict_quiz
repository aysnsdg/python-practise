def ikilik(n):
    r=""
    while n!=0:
        q=n%2
        r=str(q)+r
        n//=2
    return r

def is_palindrome(number):
    lamp=0
    if ikilik(number)[::-1]==ikilik(number) and str(number)[::-1]==str(number):
        lamp=1
    else:
        if ikilik(number)[::-1]==ikilik(number) and not str(number)[::-1]==str(number):
            lamp=2
        elif not ikilik(number)[::-1]==ikilik(number) and str(number)[::-1]==str(number):
            lamp=3

    return lamp
number=int(input("Enter a number (N>0):"))
if is_palindrome(number)==1:
    print("Palindrome type is decimal and binary")
elif is_palindrome(number)==2:
    print("Palindrome type is only binary")
elif is_palindrome(number)==3:
    print("Palindrome type is only decimal")
else:
    print("palindrome type is neither decimal nor binary")

