def uzunluq(a):
    n=0
    for i in a:
        n+=1
    return n

def mysort(a):
    n=uzunluq(a)
    for i in range(n-1):
        for j in range(n-2,i-1,-1):
            if a[j+1]<a[j]:
                a[j],a[j+1]=a[j+1],a[j]
    return a

def binary_search(a,x):
    left=0
    right=uzunluq(a)-1
    count=0
    while left<=right:
        mid=(left+right)//2
        if x==a[mid]:
            count+=1
        else:
            if x>a[mid]:
                left=mid+1
            else:
                right=mid-1
    if count==0:
        return 0
    else:
        return count

