    for i in range(n-1):
        for j in range(n-2,i-1,-1):
            if a[j+1]<a[j]:
                a[j],a[j+1]=a[j+1],a[j]
    return a

def binary_search(A, target):
   left = 0
   right = uzunluq(A) - 1
   count = 0
   while left <= right:
       mid = (left + right) // 2
       count += 1
       if target == A[mid]:
           return count
       else:
           if target > A[mid]:
               left = mid + 1
           else:
               right = mid - 1
   return -1

