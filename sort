def tek(num):
    n=0
    while num!=0:
        if num%10%2==1:
            n+=1
        num//=10
    return n

def cut(num):
    n=0
    while num!=0:
        if num%10%2==0:
            n+=1
        num//=10
    return n

def azsort(a):
    n=uzunluq(a)
    for i in range(n-1):
        for j in range(n-2,i-1,-1):
            if cut(a[j+1])>cut(a[j]):
                a[j+1],a[j]=a[j],a[j+1]
    return a

def coxsort(a):
    n=uzunluq(a)
    for i in range(n-1):
        for j in range(n-2,i-1,-1):
            if tek(a[j+1])<tek(a[j]):
                a[j+1],a[j]=a[j],a[j+1]
    return a

