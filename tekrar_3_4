def length(num):
    n=0
    while num!=0:
        n+=1
        num//=10
    return n

def look_and_say(num):
    new=""
    if length(num)%2==1:
        return "invalid"
    else:
        while num!=0:
            req=num%100
            new=str(req%10)*(req//10)+new
            num//=100
    return new

n=int(input("Enter a number (N>0): "))
print(look_and_say(n))
