    r=0
    copy=n
    while n!=0:
        r=r*10+n%10
        n//=10
    if r==copy:
        return True
    return False

def to_Binary(n):
    r=0
    p=1
    while n!=0:
        rem=n%2
        r=r+p*rem
        p*=10
        n//=2
    return r

def palindrome_type(n):
    b=to_Binary(n)
    if is_palindrome(n) and is_palindrome(b):
        return "Palindrome type is Decimal and Binary."
